{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f scripts/snapshot-before-write.py ] && python3 scripts/snapshot-before-write.py \"$FILE_PATH\" || true",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
