{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f scripts/snapshot-before-write.py ] && python3 scripts/snapshot-before-write.py \"$FILE_PATH\" || true",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -f scripts/check_update.py ] && python3 scripts/check_update.py || true",
            "timeout": 5
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -f scripts/post-compact-reminder.py ] && python3 scripts/post-compact-reminder.py || true",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
